NODE_ENV=production
PORT=3100

# Banco de dados
DATABASE_URL=postgresql://zapnit:zapnit@db:5432/zapnit?connection_limit=10&pool_timeout=30

# Redis (BullMQ)
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Meta / WhatsApp
META_APP_SECRET=seu-meta-app-secret
META_GRAPH_API_VERSION=v25.0

# Admin
ADMIN_SECRET=troque-por-uma-string-secreta

# CORS — domínio do frontend
CORS_ORIGINS=https://zapnit.frsolutions.pro

# URL pública da API (usada para registrar webhooks)
API_BASE_URL=https://api.zapnit.frsolutions.pro

# Postgres (usado pelo docker-compose para criar o banco)
POSTGRES_PASSWORD=zapnit
