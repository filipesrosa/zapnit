NODE_ENV=production
PORT=3100

# Banco de dados
# O estado de auth do Baileys (sessões Signal) vive no Postgres: cada instância
# conectada faz leituras/escritas no hot path de mensagens. Com muitas instâncias
# simultâneas, aumente connection_limit (e o tamanho do pool do Postgres) para
# evitar esgotamento do pool / timeouts.
DATABASE_URL=postgresql://zapnit:zapnit@db:5432/zapnit?connection_limit=10&pool_timeout=30

# Redis (BullMQ)
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Meta / WhatsApp
META_APP_SECRET=seu-meta-app-secret
META_GRAPH_API_VERSION=v25.0

# Admin
ADMIN_SECRET=troque-por-uma-string-secreta

# CORS — domínio do frontend
CORS_ORIGINS=https://zapnit.frsolutions.pro

# URL pública da API (usada para registrar webhooks)
API_BASE_URL=https://api.zapnit.frsolutions.pro

# URL pública do frontend (usada em redirect URLs do billing)
APP_BASE_URL=https://zapnit.frsolutions.pro

# Gateway de pagamento: mercadopago (padrão) ou stripe
PAYMENT_GATEWAY=mercadopago

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=seu-secret-para-validar-webhooks-mp

# Stripe (quando PAYMENT_GATEWAY=stripe)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Postgres (usado pelo docker-compose para criar o banco)
POSTGRES_PASSWORD=zapnit
